# --- ARDUINO MEGA (Controlador de Bajo Nivel) ---
# Arduino Mega Original (ATmega16U2)
SUBSYSTEM=="tty", ATTRS{idVendor}=="2341", ATTRS{idProduct}=="0042", SYMLINK+="arduino_mega", MODE="0666"

# Arduino Mega Generico (CH340 / CH341)
SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="7523", SYMLINK+="arduino_mega", MODE="0666"

# --- TNC USB (UHF Bridge) ---
# TNC Genérico (Ej: CP2102) - AJUSTAR CON lsusb si es diferente
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", SYMLINK+="ttyTNC", MODE="0666"

# Mobilinkd TNC3/TNC4
SUBSYSTEM=="tty", ATTRS{idVendor}=="16c0", ATTRS{idProduct}=="05e1", SYMLINK+="ttyTNC", MODE="0666"

# --- REGLAS GENÉRICAS (Comentadas para evitar conflictos Multi-Link) ---
# SUBSYSTEM=="tty", KERNEL=="ttyACM*", SYMLINK+="arduino_mega", MODE="0666"
# SUBSYSTEM=="tty", KERNEL=="ttyUSB*", SYMLINK+="arduino_mega", MODE="0666"
